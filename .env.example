# ─────────────────────────────────────────
# 나의 가상 서재 — 서버 환경변수 설정
# ─────────────────────────────────────────

# Google Gemini API 키 (필수)
# https://aistudio.google.com/app/apikey 에서 무료 발급 가능
GEMINI_API_KEY=여기에_API_키를_입력하세요

# 사용할 Gemini 모델 (선택 — 기본값: gemini-2.5-flash-preview-05-20)
# 예시: gemini-2.5-flash-preview-05-20 / gemini-2.0-flash / gemini-3-flash-preview
GEMINI_MODEL=gemini-2.5-flash-preview-05-20

# 서버 포트 (기본값: 3000)
PORT=3000
